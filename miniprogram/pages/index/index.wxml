<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索 Instagram 博主..." bindinput="onSearchInput" />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <view class="add-bar">
    <input class="add-input" placeholder="输入用户名添加博主" bindinput="onAddInput" />
    <button class="add-btn" type="primary" bindtap="onAdd">添加</button>
  </view>

  <view wx:if="{{loading}}" class="loading-text">加载中...</view>

  <view wx:if="{{!loading and bloggers.length == 0}}" class="empty-text">
    还没有添加博主，在上方输入用户名开始吧
  </view>

  <scroll-view wx:if="{{!loading}}" class="blogger-list" scroll-y bindscrolltolower="onLoadMore">
    <view class="card" wx:for="{{bloggers}}" wx:key="id" bindtap="onTapBlogger" data-username="{{item.username}}">
      <view class="blogger-card-inner">
        <image class="avatar" src="{{item.profile_pic_url}}" mode="aspectFill" />
        <view class="info">
          <view class="username">@{{item.username}}</view>
          <view class="fullname">{{item.full_name}}</view>
          <view class="stats">
            <text>{{item.followers_count}} 粉丝</text>
            <text>{{item.media_count}} 帖子</text>
          </view>
        </view>
        <view class="arrow">&gt;</view>
      </view>
    </view>
  </scroll-view>
</view>
