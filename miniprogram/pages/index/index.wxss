.page {
  padding: 20rpx;
}

.search-bar, .add-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.search-input, .add-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #eee;
}

.search-btn, .add-btn {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
}

.blogger-list {
  height: calc(100vh - 280rpx);
}

.blogger-card-inner {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.username {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
}

.fullname {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stats {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}
